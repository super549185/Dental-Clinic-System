<Window x:Class="Dental_Clinic_System.LogoutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Confirm Logout" Height="180" Width="350"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="White"
        AllowsTransparency="True">

    <Border BorderBrush="#006B6B" BorderThickness="1" CornerRadius="8">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Icon -->
            <TextBlock Text="⚠️" FontSize="32" HorizontalAlignment="Center" Grid.Row="0" Margin="0,10,0,5"/>

            <!-- Message -->
            <TextBlock Text="Are you sure you want to logout?"
                       FontSize="14" FontWeight="Medium"
                       HorizontalAlignment="Center"
                       Foreground="#333"
                       Grid.Row="1" Margin="0,5"/>

            <!-- Buttons -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,5">
                <Button x:Name="YesButton" Content="Yes, Logout"
                        Width="110" Height="35"
                        Background="#006B6B" Foreground="White"
                        BorderThickness="0" FontSize="13"
                        Click="YesButton_Click"
                        Margin="0,0,10,0"/>
                <Button x:Name="NoButton" Content="Cancel"
                        Width="90" Height="35"
                        Background="#F5F5F5" Foreground="#333"
                        BorderThickness="1" BorderBrush="#CCC"
                        FontSize="13"
                        Click="NoButton_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>