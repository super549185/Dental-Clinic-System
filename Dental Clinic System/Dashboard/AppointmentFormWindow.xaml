<Window x:Class="Dental_Clinic_System.Dashboard.AppointmentFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Appointment" Height="550" Width="420"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="Transparent" WindowStyle="None" AllowsTransparency="True">

    <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="10" Background="White">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Header -->
                <RowDefinition Height="*"/>
                <!-- Form -->
                <RowDefinition Height="Auto"/>
                <!-- Buttons -->
            </Grid.RowDefinitions>

            <!-- CLEAN HEADER -->
            <Border Grid.Row="0" Background="#006B6B" CornerRadius="10,10,0,0" Padding="25,20">
                <Grid>
                    <StackPanel>
                        <TextBlock x:Name="FormTitle" Text="New Appointment" FontSize="20" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Fill in the details below" FontSize="12" Foreground="#A7F3D0" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top"
                            Background="Transparent" Foreground="White" BorderThickness="0" 
                            FontSize="16" Cursor="Hand" Width="28" Height="28"
                            Click="Cancel_Click"/>
                </Grid>
            </Border>

            <!-- FORM FIELDS -->
            <StackPanel Grid.Row="1" Margin="25,20,25,10">

                <!-- Patient Name -->
                <TextBlock Text="PATIENT NAME" FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" Margin="0,0,0,5"/>
                <TextBox x:Name="PatientNameBox" Height="38" Padding="10,0" 
                         Background="#F9FAFB" BorderThickness="1" BorderBrush="#E5E7EB" 
                         FontSize="13" VerticalContentAlignment="Center"/>

                <Border Height="15"/>

                <!-- Dentist -->
                <TextBlock Text="DENTIST" FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" Margin="0,0,0,5"/>
                <ComboBox x:Name="DentistBox" Height="38" Padding="10,0" 
                          Background="#F9FAFB" BorderThickness="1" BorderBrush="#E5E7EB" 
                          FontSize="13" VerticalContentAlignment="Center" SelectedIndex="0">
                    <ComboBoxItem Content="Dr. Santos"/>
                    <ComboBoxItem Content="Dr. Reyes"/>
                    <ComboBoxItem Content="Dr. Cruz"/>
                </ComboBox>

                <Border Height="15"/>

                <!-- Service -->
                <TextBlock Text="SERVICE" FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" Margin="0,0,0,5"/>
                <ComboBox x:Name="ServiceBox" Height="38" Padding="10,0" 
                          Background="#F9FAFB" BorderThickness="1" BorderBrush="#E5E7EB" 
                          FontSize="13" VerticalContentAlignment="Center" SelectedIndex="0">
                    <ComboBoxItem Content="Cleaning"/>
                    <ComboBoxItem Content="Root Canal"/>
                    <ComboBoxItem Content="Tooth Extraction"/>
                    <ComboBoxItem Content="Braces Adjustment"/>
                    <ComboBoxItem Content="Teeth Whitening"/>
                    <ComboBoxItem Content="Dental Checkup"/>
                </ComboBox>

                <Border Height="15"/>

                <!-- Date & Time Row -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="DATE" FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" Margin="0,0,0,5"/>
                        <DatePicker x:Name="DateBox" Height="38" Padding="10,0" 
                                    Background="#F9FAFB" BorderBrush="#E5E7EB" 
                                    VerticalContentAlignment="Center" FontSize="13"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="TIME" FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" Margin="0,0,0,5"/>
                        <ComboBox x:Name="TimeBox" Height="38" Padding="10,0" 
                                  Background="#F9FAFB" BorderThickness="1" BorderBrush="#E5E7EB" 
                                  FontSize="13" VerticalContentAlignment="Center" SelectedIndex="0">
                            <ComboBoxItem Content="09:00 AM"/>
                            <ComboBoxItem Content="10:00 AM"/>
                            <ComboBoxItem Content="11:00 AM"/>
                            <ComboBoxItem Content="01:00 PM"/>
                            <ComboBoxItem Content="02:00 PM"/>
                            <ComboBoxItem Content="03:00 PM"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <Border Height="15"/>

                <!-- Status (Pending Removed) -->
                <TextBlock Text="STATUS" FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" Margin="0,0,0,5"/>
                <ComboBox x:Name="StatusBox" Height="38" Padding="10,0" 
                          Background="#F9FAFB" BorderThickness="1" BorderBrush="#E5E7EB" 
                          FontSize="13" VerticalContentAlignment="Center" SelectedIndex="0">
                    <ComboBoxItem Content="Confirmed"/>
                    <ComboBoxItem Content="Cancelled"/>
                </ComboBox>

            </StackPanel>

            <!-- BUTTONS -->
            <Grid Grid.Row="2" Margin="25,0,25,25">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="Cancel" Height="40" 
                        Background="#F3F4F6" Foreground="#374151" BorderThickness="0" 
                        FontSize="14" FontWeight="Medium" Cursor="Hand" Click="Cancel_Click"/>

                <Button Grid.Column="2" Content="Save Appointment" Height="40" 
                        Background="#006B6B" Foreground="White" BorderThickness="0" 
                        FontSize="14" FontWeight="SemiBold" Cursor="Hand" Click="Save_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>