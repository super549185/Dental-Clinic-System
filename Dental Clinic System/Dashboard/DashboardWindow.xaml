<Window x:Class="Dental_Clinic_System.Dashboard.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Dental_Clinic_System.Dashboard"
        mc:Ignorable="d"
        Title="DashboardWindow" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Colors -->
        <SolidColorBrush x:Key="SidebarBg" Color="#006B6B"/>
        <SolidColorBrush x:Key="SidebarText" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="ActiveBg" Color="#E3F2FD"/>
        <SolidColorBrush x:Key="ActiveText" Color="#1565C0"/>
        <SolidColorBrush x:Key="HoverBg" Color="Aquamarine"/>

        <!-- Compact Sidebar Item Style -->
        <Style x:Key="CompactSidebarItemStyle" TargetType="ListBoxItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}"
                                Padding="12,6" 
                                Height="36">
                            <!-- Fixed height ensures uniformity -->
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="{StaticResource SidebarText}"/>
            <Setter Property="FontSize" Value="13"/>
            <!-- Slightly smaller font -->
            <Setter Property="FontWeight" Value="Normal"/>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource HoverBg}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource ActiveBg}"/>
                    <Setter Property="Foreground" Value="{StaticResource ActiveText}"/>
                    <Setter Property="FontWeight" Value="Medium"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBg}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Brand / Title (Compact) -->
                <StackPanel Grid.Row="0" Margin="15,15,15,10">
                    <TextBlock Text="Dental Clinic" 
                               FontSize="14" 
                               FontWeight="Bold" 
                               Foreground="White"/>
                    <TextBlock Text="System" 
                               FontSize="10" 
                               Foreground="#A5D6A7" 
                               Margin="0,0,0,0"/>
                </StackPanel>

                <!-- Navigation Menu (No Margins on items to save space) -->
                <ListBox x:Name="SidebarMenu" 
                         Grid.Row="1" 
                         BorderThickness="0" 
                         Background="Transparent"
                         ItemContainerStyle="{StaticResource CompactSidebarItemStyle}">

                    <ListBoxItem Content="Dashboard" IsSelected="True"/>
                    <ListBoxItem Content="Appointments"/>
                    <ListBoxItem Content="Patients"/>
                    <ListBoxItem Content="Dentists &amp; Staff"/>
                    <ListBoxItem Content="Services"/>
                    <ListBoxItem Content="Billing"/>
                    <ListBoxItem Content="Notifications"/>
                    <ListBoxItem Content="Inventory"/>
                    <ListBoxItem Content="Reports"/>
                    <ListBoxItem Content="Settings"/>
                </ListBox>

                <!-- Logout Section (Compact) -->
                <Button Grid.Row="2" 
                        Content="Logout" 
                        Background="Transparent" 
                        Foreground="#EF9A9A"
                        BorderThickness="0"
                        HorizontalAlignment="Stretch"
                        Padding="12,8"
                        Cursor="Hand"
                        FontWeight="Medium"
                        Height="36"
                        Margin="0,0,0,10">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" 
                                                Padding="{TemplateBinding Padding}"
                                                Height="{TemplateBinding Height}">
                                            <TextBlock Text="{TemplateBinding Content}" 
                                                       Foreground="{TemplateBinding Foreground}"
                                                       FontSize="13"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <!-- MAIN CONTENT AREA -->
        <Border Grid.Column="1" Background="White">
            <Grid>
                <StackPanel Margin="30" VerticalAlignment="Top">
                    <TextBlock Text="Dashboard" FontSize="24" FontWeight="Bold" Foreground="#333"/>
                    <TextBlock Text="Welcome back, Doctor" FontSize="14" Foreground="#666" Margin="0,5,0,0"/>

                    <!-- Content Placeholder -->
                    <Rectangle Fill="#F5F5F5" Height="300" Width="Auto" RadiusX="10" RadiusY="10" Margin="0,30,0,0" Stroke="#EEE"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>