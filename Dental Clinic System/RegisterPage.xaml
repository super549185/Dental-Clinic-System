<Page x:Class="Dental_Clinic_System.RegisterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:local="clr-namespace:Dental_Clinic_System"
      mc:Ignorable="d"
      Background="White">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*" />
            <!-- Registration panel -->
            <ColumnDefinition Width="2*" />
            <!-- Welcome panel -->
        </Grid.ColumnDefinitions>

        <!-- LEFT: Registration -->
        <Border Grid.Column="0" Background="White" Padding="60">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Text="                Registration"
                           FontSize="28" FontWeight="Bold" 
                           Margin="0,0,0,30"/>

                <StackPanel Grid.Row="1" VerticalAlignment="Top">

                    <!-- Full Name -->
                    <Grid Height="40" Background="#EFEFEF" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="FullNameTextBox"
                                 Grid.Column="0"
                                 VerticalContentAlignment="Center"
                                 Padding="12,0"
                                 Text="Full Name"
                                 Foreground="Gray"
                                 Background="#EFEFEF"
                                 BorderThickness="0"
                                 FontSize="14"
                                 GotFocus="FullNameTextBox_GotFocus"
                                 LostFocus="FullNameTextBox_LostFocus"/>

                        <Border Grid.Column="1" Width="36" Height="40" Background="Transparent">
                            <!--<Image Source="/Images/id-card.png" Width="22" Height="22"/> -->
                        </Border>
                    </Grid>

                    <!-- Clinic Name -->
                    <Grid Height="40" Background="#EFEFEF" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="ClinicNameTextBox"
         Grid.Column="0"
         VerticalContentAlignment="Center"
         Padding="12,0"
         Text="Clinic Name"
         Foreground="Gray"
         Background="#EFEFEF"
         BorderThickness="0"
         FontSize="14"
         GotFocus="ClinicNameTextBox_GotFocus"
         LostFocus="ClinicNameTextBox_LostFocus"/>
                        <Border Grid.Column="1" Width="36" Height="40" Background="Transparent">
                           <!-- <Image Source="/Images/dentist.png" Width="22" Height="22"/> -->
                        </Border>
                    </Grid>

                    <!-- Username -->
                    <Grid Height="40" Background="#EFEFEF" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="UsernameTextBox"
                                 Grid.Column="0"
                                 VerticalContentAlignment="Center"
                                 Padding="12,0"
                                 Text="Username"
                                 Foreground="Gray"
                                 Background="#EFEFEF"
                                 BorderThickness="0"
                                 FontSize="14"
                                 GotFocus="UserNameTextBox_GotFocus"
                                 LostFocus="UserNameTextBox_LostFocus"/>

                        <Border Grid.Column="1" Width="36" Height="40" Background="Transparent">
                            <!-- <Image Source="/Images/user.png" Width="22" Height="22"/> -->
                        </Border>
                    </Grid>

                    <!-- Email -->
                    <Grid Height="40" Background="#EFEFEF" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="EmailTextBox"
                                 Grid.Column="0"
                                 VerticalContentAlignment="Center"
                                 Padding="12,0"
                                 Text="Email"
                                 Foreground="Gray"
                                 Background="#EFEFEF"
                                 BorderThickness="0"
                                 FontSize="14"
                                 GotFocus="EmailTextBox_GotFocus"
                                 LostFocus="EmailTextBox_LostFocus"/>

                        <Border Grid.Column="1" Width="36" Height="40" Background="Transparent">
                            <!-- <Image Source="/Images/email.png" Width="22" Height="22"/> -->
                        </Border>
                    </Grid>

                    <!-- Password -->
                    <Grid Height="40" Background="#EFEFEF" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Hidden password -->
                        <PasswordBox x:Name="PasswordBox"
                 Grid.Column="0"
                 VerticalContentAlignment="Center"
                 Padding="12,0"
                 Background="#EFEFEF"
                 BorderThickness="0"
                 FontSize="14"
                 GotFocus="PasswordBox_GotFocus"
                 LostFocus="PasswordBox_LostFocus"
                 PasswordChanged="PasswordBox_PasswordChanged"/>

                        <!-- Visible password -->
                        <TextBox x:Name="PasswordTextBox"
         Grid.Column="0"
         VerticalContentAlignment="Center"
         Padding="12,0"
         Background="#EFEFEF"
         BorderThickness="0"
         FontSize="14"
         Visibility="Collapsed"
         GotFocus="PasswordTextBox_GotFocus"
         LostFocus="PasswordTextBox_LostFocus"
         TextChanged="PasswordTextBox_TextChanged"/>


                        <TextBlock x:Name="PasswordPlaceholder"
               Text="Password"
               Foreground="Gray"
               FontSize="14"
               Margin="12,0,0,0"
               VerticalAlignment="Center"
               IsHitTestVisible="False"/>

                        <!-- Eye button -->
                        <Border Grid.Column="1" Width="36" Height="40">
                            <Button x:Name="TogglePasswordButton"
                Width="36"
                Height="40"
                Background="Transparent"
                BorderBrush="{x:Null}"
                Click="TogglePassword_Click">
                                <TextBlock x:Name="PasswordEyeIcon"
                       Text="👁"
                       FontSize="16"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
                            </Button>
                        </Border>
                    </Grid>

                    <!-- Confirm Password -->
                    <Grid Height="40" Background="#EFEFEF" Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Hidden password -->
                        <PasswordBox x:Name="ConfirmPasswordBox"
                 Grid.Column="0"
                 VerticalContentAlignment="Center"
                 Padding="12,0"
                 Background="#EFEFEF"
                 BorderThickness="0"
                 FontSize="14"
                 GotFocus="ConfirmPasswordBox_GotFocus"
                 LostFocus="ConfirmPasswordBox_LostFocus"
                 PasswordChanged="ConfirmPasswordBox_PasswordChanged"/>

                        <!-- Visible password -->
                        <TextBox x:Name="ConfirmPasswordTextBox"
         Grid.Column="0"
         VerticalContentAlignment="Center"
         Padding="12,0"
         Background="#EFEFEF"
         BorderThickness="0"
         FontSize="14"
         Visibility="Collapsed"
         GotFocus="ConfirmPasswordTextBox_GotFocus"
         LostFocus="ConfirmPasswordTextBox_LostFocus"
         TextChanged="ConfirmPasswordTextBox_TextChanged"/>

                        <TextBlock x:Name="ConfirmPasswordPlaceholder"
               Text="Confirm Password"
               Foreground="Gray"
               FontSize="14"
               Margin="12,0,0,0"
               VerticalAlignment="Center"
               IsHitTestVisible="False"/>

                        <!-- Eye button -->
                        <Border Grid.Column="1" Width="36" Height="40">
                            <Button x:Name="ToggleConfirmPasswordButton"
                Width="36"
                Height="40"
                Background="Transparent"
                BorderBrush="{x:Null}"
                Click="ToggleConfirmPassword_Click">
                                <TextBlock x:Name="ConfirmEyeIcon"
                       Text="👁"
                       FontSize="16"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
                            </Button>
                        </Border>
                    </Grid>

                    <!-- Register Button -->
                    <Button x:Name="RegisterButton"
                            Content="Register"
                            Height="40"
                            Background="#006B6B"
                            Foreground="White"
                            BorderThickness="0"
                            FontSize="14"
                            Click="RegisterButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- RIGHT PANEL -->
        <Border Grid.Column="1" Background="#006B6B">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="WELCOME BACK!" Foreground="White"
                           FontSize="26" FontWeight="Bold" TextAlignment="Center" Margin="0,0,0,10"/>

                <TextBlock Text="Already have an account?"
                           Foreground="White" Opacity="0.9"
                           FontSize="14" TextAlignment="Center" Margin="0,0,0,10"/>

                <Button x:Name="LoginButton"
                        Content="Login"
                        Width="100" Height="35"
                        Background="Transparent"
                        BorderBrush="White"
                        Foreground="White"
                        BorderThickness="1"
                        Click="LoginButton_Click"/>
            </StackPanel>
        </Border>

    </Grid>
</Page>