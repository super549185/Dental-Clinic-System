<Page x:Class="Dental_Clinic_System.Dashboard.AppointmentPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F9FAFB">

    <Grid Margin="30,25,30,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Appointments" FontSize="26" FontWeight="Bold" Foreground="#111827"/>
                <TextBlock Text="Manage all clinic appointments" FontSize="13" Foreground="#9CA3AF" Margin="0,4,0,0"/>
            </StackPanel>

            <Button Grid.Column="1" Content="Add Appointment" Background="#10B981" Foreground="White" 
                    BorderThickness="0" Padding="15,10" FontSize="14" FontWeight="SemiBold" Cursor="Hand"
                    Click="AddAppointment_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="16" 
                                           VerticalAlignment="Center" Margin="0,0,8,0" Foreground="White"/>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#059669"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <!-- FILTER TABS & TABLE WRAPPER -->
        <Border Grid.Row="2" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- FILTER TABS -->
                <Border Grid.Row="0" Background="White" Padding="15,0" Margin="0">
                    <StackPanel Orientation="Horizontal">

                        <!-- Tab 1: All -->
                        <Border x:Name="TabAll" BorderBrush="#006B6B" BorderThickness="0,0,0,2" Margin="0,0,5,0" Padding="16,12" Cursor="Hand" MouseLeftButtonUp="Filter_Click" Tag="All">
                            <TextBlock Text="All Appointments" FontSize="14" FontWeight="SemiBold" Foreground="#006B6B"/>
                        </Border>

                        <!-- Tab 2: Confirmed -->
                        <Border x:Name="TabConfirmed" BorderThickness="0" Margin="0,0,5,0" Padding="16,12" Cursor="Hand" MouseLeftButtonUp="Filter_Click" Tag="Confirmed">
                            <TextBlock Text="Confirmed" FontSize="14" FontWeight="Medium" Foreground="#6B7280"/>
                        </Border>

                        <!-- Tab 3: Cancelled -->
                        <Border x:Name="TabCancelled" BorderThickness="0" Margin="0,0,5,0" Padding="16,12" Cursor="Hand" MouseLeftButtonUp="Filter_Click" Tag="Cancelled">
                            <TextBlock Text="Cancelled" FontSize="14" FontWeight="Medium" Foreground="#6B7280"/>
                        </Border>

                        <!-- Tab 4: Today -->
                        <Border x:Name="TabToday" BorderThickness="0" Padding="16,12" Cursor="Hand" MouseLeftButtonUp="Filter_Click" Tag="Today">
                            <TextBlock Text="Today's Appointments" FontSize="14" FontWeight="Medium" Foreground="#6B7280"/>
                        </Border>

                    </StackPanel>
                </Border>

                <!-- TABLE HEADER -->
                <Border Grid.Row="1" Background="#F9FAFB" Height="45" BorderBrush="#E5E7EB" BorderThickness="0,1,0,1">
                    <Grid Margin="24,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="190"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="APPOINTMENT ID" FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="PATIENT NAME" FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="DENTIST" FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="SERVICE" FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text="DATE &amp; TIME" FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="5" Text="STATUS" FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="6" Text="ACTIONS" FontSize="11" FontWeight="SemiBold" Foreground="#6B7280" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- DATA ROWS -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="AppointmentList"/>
                </ScrollViewer>

                <!-- EMPTY STATE -->
                <TextBlock x:Name="EmptyState" Text="No appointments found for this filter." FontSize="16" Foreground="#9CA3AF" 
                           HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Row="2" Visibility="Collapsed"/>
            </Grid>
        </Border>
    </Grid>
</Page>