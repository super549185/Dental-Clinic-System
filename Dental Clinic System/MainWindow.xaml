<Window x:Class="Dental_Clinic_System.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:Dental_Clinic_System"
    mc:Ignorable="d"
    Title="Dental Management System" Height="600" Width="900"
    WindowStartupLocation="CenterScreen"
    ResizeMode="NoResize"
    Background="White">

    <Grid>

        <!-- FRAME FOR PAGE NAVIGATION -->
        <Frame x:Name="MainFrame"
            NavigationUIVisibility="Hidden"
            Visibility="Collapsed" />

        <!-- LOGIN UI SECTION -->
        <Grid x:Name="LoginGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- LEFT PANEL -->
            <Border Background="#006B6B" Grid.Column="0">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                    <TextBlock Text="HELLO, WELCOME!"
                            FontSize="28"
                            FontWeight="Bold"
                            Foreground="White"
                            HorizontalAlignment="Center"
                            Margin="0 0 0 10"/>

                    <TextBlock Text="You don't have an account?"
                            Foreground="White"
                            FontSize="14"
                            HorizontalAlignment="Center"/>

                    <Button x:Name="regButton" Content="Register"
                         Width="150"
                         Height="35"
                         Margin="0 20 0 0"
                         Background="Transparent"
                         BorderBrush="White"
                         Foreground="White"
                         FontSize="16"
                         Click="regButton_Click"/>
                </StackPanel>
            </Border>

            <!-- RIGHT PANEL -->
            <Grid Grid.Column="1">
                <StackPanel Width="300" HorizontalAlignment="Center" VerticalAlignment="Center">

                    <!-- Logo -->
                    <!-- <Image Source="/Images/tooth.png" Height="120" Margin="0 0 0 20"/> -->

                    <!-- Username Box -->
                    <DockPanel Margin="0 0 0 10" Background="#EFEFEF">
                        <TextBox x:Name="UsernameBox"
                              KeyDown="Input_KeyDown"
                              Height="35" Width="314" Padding="10"
                              Background="#EFEFEF" BorderThickness="0"
                              Text="Username"
                              Foreground="Gray"
                              VerticalContentAlignment="Center"
                              GotFocus="UsernameBox_GotFocus"
                              LostFocus="UsernameBox_LostFocus"/>
                      <!--   <Image Source="/Images/user.png"      
                            DockPanel.Dock="Right" Width="30" /> -->
                    </DockPanel>

                    <!-- Password Box -->
                    <Grid Margin="0 0 0 10" Background="#EFEFEF" Height="35" Width="300">

                        <!-- Hidden password -->
                        <PasswordBox x:Name="LoginPasswordBox"
              KeyDown="Input_KeyDown"
              Padding="10"
              Background="#EFEFEF"
              BorderThickness="0"
              GotFocus="PasswordBox_GotFocus"
              LostFocus="PasswordBox_LostFocus"/>

                        <!-- Visible password -->
                        <TextBox x:Name="LoginPasswordTextBox"
          Padding="10"
          Background="#EFEFEF"
          BorderThickness="0"
          Visibility="Collapsed"/>

                        <TextBlock x:Name="PasswordPlaceholder"
            Text="Password"
            Foreground="Gray"
            Margin="10 0 0 0"
            VerticalAlignment="Center"
            IsHitTestVisible="False"/>

                        <!-- Eye button -->
                        <Button x:Name="ToggleLoginPasswordButton"
         Width="30"
         Height="30"
         Background="Transparent"
         BorderBrush="{x:Null}"
         HorizontalAlignment="Left"
         VerticalAlignment="Center"
         Margin="260,0,0,0"
         Click="ToggleLoginPassword_Click">
                            <TextBlock x:Name="LoginEyeIcon"
                Text="👁"
                FontSize="14"/>
                        </Button>
                    </Grid>
                    <!-- Error Message -->
                    <TextBlock x:Name="ErrorMessage"
                            Text="Invalid username or password."
                            Foreground="Red"
                            FontSize="12"
                            Visibility="Collapsed"
                            Margin="3 0 0 5"/>


                    <TextBlock Text="Forgot Password?"
                            Foreground="Gray"
                            HorizontalAlignment="Right"
                            Margin="0 0 0 15"
                            TextDecorations="Underline"/>

                    <!-- Login Button -->
                    <Button x:Name="loginButton" Content="Login"
                         Height="40"
                         Width="250"
                         Background="#006B6B"
                         Foreground="White"
                         BorderThickness="0"
                         FontSize="16"
                         Click="loginButton_Click"/>

                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>